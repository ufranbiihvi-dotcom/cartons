    nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    nameLabel.TextSize = 14
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextStrokeTransparency = 0
    nameLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    nameLabel.Parent = mainFrame

    -- Fondo de la barra de vida
    local healthBackground = Instance.new("Frame")
    healthBackground.Size = UDim2.new(0, 4, 1, 0)
    healthBackground.Position = UDim2.new(0, -10, 0, 0)
    healthBackground.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    healthBackground.BorderSizePixel = 0
    healthBackground.Parent = mainFrame

    -- Barra de vida (Relleno)
    local healthBar = Instance.new("Frame")
    healthBar.Size = UDim2.new(1, 0, 1, 0)
    healthBar.BorderSizePixel = 0
    healthBar.Parent = healthBackground

    espStorage[targetPlayer] = {
        Billboard = billboard,
        Bar = healthBar,
        BoxStroke = boxStroke
    }
end

local function removeESPVisuals(targetPlayer)
    if espStorage[targetPlayer] then
        espStorage[targetPlayer].Billboard:Destroy()
        espStorage[targetPlayer] = nil
    end
end

-- Bucle Principal del ESP
local function startESP()
    if espConnection then return end
    
    espConnection = RunService.RenderStepped:Connect(function()
        for _, plr in ipairs(game.Players:GetPlayers()) do
            if plr ~= player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and plr.Character:FindFirstChildOfClass("Humanoid") then
                local char = plr.Character
                local hum = char:FindFirstChildOfClass("Humanoid")
                local root = char.HumanoidRootPart
                
                if not espStorage[plr] then
                    createESPVisuals(plr)
                end
                
                local data = espStorage[plr]
                if data then
                    data.Billboard.Adornee = root
                    data.Billboard.Parent = player:WaitForChild("PlayerGui")
                    
                    -- Actualizar barra de vida
                    local healthPercentage = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
                    data.Bar.Size = UDim2.new(1, 0, healthPercentage, 0)
                    data.Bar.Position = UDim2.new(0, 0, 1 - healthPercentage, 0)
                    
                    -- Cambiar color según el 50% de vida
                    if healthPercentage >= 0.5 then
                        data.Bar.BackgroundColor3 = Color3.fromRGB(0, 255, 100) -- Verde
                        data.BoxStroke.Color = Color3.fromRGB(0, 255, 100)
                    else
                        data.Bar.BackgroundColor3 = Color3.fromRGB(255, 50, 50) -- Rojo
                        data.BoxStroke.Color = Color3.fromRGB(255, 50, 50)
                    end
                end
            else
                removeESPVisuals(plr)
            end
        end
    end)
end

local function stopESP()
    if espConnection then
        espConnection:Disconnect()
        espConnection = nil
    end
    for plr, _ in pairs(espStorage) do
        removeESPVisuals(plr)
    end
end

game.Players.PlayerRemoving:Connect(removeESPVisuals)

local function aplicarMegaFPS()
    -- 1. Convertir a todos los jugadores en Noobs y quitarles accesorios pesados
    for _, plr in ipairs(game.Players:GetPlayers()) do
        if plr ~= player and plr.Character then
            local char = plr.Character
            
            -- Quitar accesorios (pelos, alas, sombreros gigantes)
            for _, obj in ipairs(char:GetChildren()) do
                if obj:IsA("Accessory") then
                    obj:Destroy()
                elseif obj:IsA("Shirt") or obj:IsA("Pants") or obj:IsA("ShirtGraphic") then
                    obj:Destroy()
                end
            end
            
            -- Pintar como Noob clásico
            local bodyColors = char:FindFirstChildOfClass("BodyColors")
            if not bodyColors then
                bodyColors = Instance.new("BodyColors", char)
            end
            bodyColors.TorsoColor3 = Color3.new(0, 0.4, 0.8) -- Azul
            bodyColors.LeftLegColor3 = Color3.new(0.3, 0.7, 0.3) -- Verde
            bodyColors.RightLegColor3 = Color3.new(0.3, 0.7, 0.3) -- Verde
            bodyColors.HeadColor3 = Color3.new(1, 0.8, 0) -- Amarillo
            bodyColors.LeftArmColor3 = Color3.new(1, 0.8, 0)
            bodyColors.RightArmColor3 = Color3.new(1, 0.8, 0)
        end
    end

    -- 2. Eliminar texturas del mapa y efectos visuales pesados
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") then
            obj.Material = Enum.Material.SmoothPlastic
            obj.Reflectance = 0
        elseif obj:IsA("Texture") or obj:IsA("Decal") then
            obj:Destroy()
        elseif obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Smoke") or obj:IsA("Fire") or obj:IsA("Sparkles") then
            obj:Destroy() -- Elimina por completo los efectos para liberar memoria
        end
    end
    
    -- Ajustar iluminación al mínimo esfuerzo para la gráfica
    local lighting = game:GetService("Lighting")
    lighting.GlobalShadows = false
    lighting.FogEnd = 999999
end                

