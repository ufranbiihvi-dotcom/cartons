-- ==========================================
-- OPTIMIZADOR DE FPS - TEXTURAS LISAS (NUEVO)
-- ==========================================
local function optimizeFPS()
    local terrain = workspace:FindFirstChildOfClass("Terrain")
    if terrain then
        terrain.WaterWaveSize = 0
        terrain.WaterWaveSpeed = 0
        terrain.WaterReflectance = 0
        terrain.WaterTransparency = 0
    end
    
    -- Recorrer todo el mapa para quitar texturas pesadas
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and not obj:IsA("MeshPart") then
            -- Cambiar material a Plástico Liso para máxima fluidez
            obj.Material = Enum.Material.SmoothPlastic
        elseif obj:IsA("Texture") or obj:IsA("Decal") then
            -- Eliminar texturas e imágenes del suelo/paredes
            obj:Destroy()
        elseif obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Smoke") or obj:IsA("Fire") then
            -- Desactivar partículas pesadas de fondo
            obj.Enabled = false
        end
    end
end

-- Ejecutar la optimización de texturas inmediatamente al cargar el script
optimizeFPS()
-- ==========================================

-- Función para encontrar el jugador más cercano
local function getClosestPlayer()
    local closest = nil
    local shortestDistance = MAX_DISTANCE
    
    for _, plr in ipairs(game.Players:GetPlayers()) do
        if plr ~= player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local root = plr.Character.HumanoidRootPart
            local distance = (player.Character and player.Character:FindFirstChild("HumanoidRootPart")) 
                and (player.Character.HumanoidRootPart.Position - root.Position).Magnitude 
                or 9999
            
            if distance < shortestDistance then
                shortestDistance = distance
                closest = plr
            end
        end
    end
    return closest
end

-- Aimlock Loop
local function startAimlock()
    if aimlockConnection then return end
    
    aimlockConnection = RunService.RenderStepped:Connect(function()
        if not AIMLOCK_ENABLED then return end
        if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return end
        
        local target = getClosestPlayer()
        if not target or not target.Character or not target.Character:FindFirstChild("Head") then return end
        
        local targetHead = target.Character.Head
        local root = player.Character.HumanoidRootPart
        
        -- Apuntar a la cabeza
        local direction = (targetHead.Position - camera.CFrame.Position).Unit
        camera.CFrame = CFrame.lookAt(camera.CFrame.Position, camera.CFrame.Position + direction)
    end)
end

local function stopAimlock()
    if aimlockConnection then
        aimlockConnection:Disconnect()
        aimlockConnection = nil
    end
end

