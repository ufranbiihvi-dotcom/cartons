-- ==========================================
-- OPTIMIZADOR DE FPS - TEXTURAS LISAS (NUEVO)
-- ==========================================
local function optimizeFPS()
    local terrain = workspace:FindFirstChildOfClass("Terrain")
    if terrain then
        terrain.WaterWaveSize = 0
        terrain.WaterWaveSpeed = 0
        terrain.WaterReflectance = 0
        terrain.WaterTransparency = 0
    end
    
    -- Recorrer todo el mapa para quitar texturas pesadas
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and not obj:IsA("MeshPart") then
            -- Cambiar material a Plástico Liso para máxima fluidez
            obj.Material = Enum.Material.SmoothPlastic
        elseif obj:IsA("Texture") or obj:IsA("Decal") then
            -- Eliminar texturas e imágenes del suelo/paredes
            obj:Destroy()
        elseif obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Smoke") or obj:IsA("Fire") then
            -- Desactivar partículas pesadas de fondo
            obj.Enabled = false
        end
    end
end

-- Ejecutar la optimización de texturas inmediatamente al cargar el script
optimizeFPS()
